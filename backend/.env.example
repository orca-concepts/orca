# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=concept_hierarchy
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (e.g. http://localhost:5173,https://yourdomain.com)
CORS_ORIGINS=http://localhost:5173

# JWT Secret (change this to a random string in production)
JWT_SECRET=change_me_to_a_random_string
JWT_EXPIRES_IN=90d

ADMIN_USER_ID=1

ENABLED_ATTRIBUTES=value

# Comma-separated list of enabled document tags. Leave empty to show all tags.
ENABLED_DOCUMENT_TAGS=preprint,protocol,grant application,review article,dataset,thesis,textbook,lecture notes,commentary

# Phone Lookup Key (HMAC-SHA256 for O(1) phone lookup - Phase 33e)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_LOOKUP_KEY=change_me_to_a_random_hex_string

# Twilio (Phone OTP Authentication - Phase 32)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# ORCID OAuth (Phase 41a)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://localhost:3000/orcid/callback
ORCID_BASE_URL=https://orcid.org